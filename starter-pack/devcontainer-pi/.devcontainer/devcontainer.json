// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.154.0/containers/python-3
{
	"name": "",
	"build": {
		"dockerfile": "./Dockerfile",
		"args": {
			"USER_ID": "${localEnv:DEV_CONTAINER_USER_ID}",
			"GROUP_ID": "${localEnv:DEV_CONTAINER_GROUP_ID}"
		}
	},
	// Set *default* container specific settings.json values on container create.
	"customizations": {
		 "vscode": {
				"settings": {},
				// Add the IDs of extensions you want installed when the container is created.
				"extensions": [
					"ms-vscode.vscode-typescript-next",
					"analytic-signal.preview-html"
				]
		 }
	},
	"containerEnv": {
		"CLOUDFLARE_ACCOUNT_ID": "${localEnv:CLOUDFLARE_ACCOUNT_ID}",
		"PI_EXPORT_DIR": "./.pi-export",
		"PI_SESSION_RENAMER_MODEL": "google/gemini-3.1-flash-lite"
	},

	"mounts": ["source=${localEnv:PI_HOME}/,target=/home/lovely/.pi,type=bind"],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "pip3 install --user -r requirements.txt",
	"postCreateCommand": "./.devcontainer/post-create.sh",

	// Comment out connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "lovely"
}
